/* #visBtn { */
  /* position: relative; */
  /* transform: translateX(55px); */
/* } */

#gameControls button {
    color: var(--color-fg);
}

#newGameBtn {
    display: flex;
    align-items: center;
}

#newGameBtn button:hover {
    cursor: pointer;
}

#newGameBtn a {
    text-decoration: none;
    color: var(--color-fg);
}

#gameInfo,
#userInfo {
    font-size: 16px;
    font-weight: 600;
    border: 2px solid var(--color-primary);
    margin-bottom: 5px;
    outline-offset: 5px;
    padding: 5px;
}

.grid {
    display: grid;
    width: max-content;
}

.cell {
  width: 30px;
  height: 30px;
  list-style: none;
  background-color: var(--color-primary);
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2px solid var(--color-primary-muted);
  border-radius: 5px;
  gap: 9px
}

.cell span {
}
