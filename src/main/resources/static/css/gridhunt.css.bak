html, body {
  height: 100%;
  margin: 0;
}

/* Page layout */
body {
  display: flex;
  flex-direction: column;
}

/* Header stays on top */
header {
  display: flex;
  justify-content: center;
  gap: 2rem;
  padding: 10px;
}

#homeBtn {
    padding: 15px;
}

header a {
  text-decoration: none;
  padding: 2px;
}

.container {
  display: flex;
  justify-content: center;
  align-items: center;
}

.gameLayout {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.gameHeader {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.gameBody {
  display: flex;
  align-items: flex-start;
  gap: 20px;
}

.gridhunt-field {
  padding: 15px 5px;
}

.gameSidebar {
  width: 150px;
}

